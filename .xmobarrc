Config
  {
  overrideRedirect = False,
  position = Bottom,
  font = "NotoSansM Nerd Font Mono Bold 12",
  additionalFonts = [ "NotoSansM Nerd Font Mono Bold 16" ],
  bgColor = "black",
  fgColor = "grey",
  alpha = 200,
  lowerOnStart = True,
  allDesktops = True,
  persistent = True,
  commands =
    [
    Run Cpu [ 
    "--template", "<fn=1></fn> <total>%", 
    "--High", "75",
    "--Low", "50",
    "--high", "red",
    "--normal", "darkorange",
    "--low", "limegreen"
    ] 50,
    Run Memory [ 
    "--template", "<fn=1>󰍛</fn> <usedratio>%",
    "--High", "75",
    "--Low", "50",
    "--high", "red",
    "--normal", "darkorange",
    "--low", "limegreen"
    ] 50,
    Run CommandReader "/home/ahaskell/.config/custom/power.sh" "power",
    Run CommandReader "/home/ahaskell/.config/custom/datetime.sh" "datetime",
    Run CommandReader "/home/ahaskell/.config/custom/wlan.sh" "wlan",
    Run CommandReader "/home/ahaskell/.config/custom/windows.sh" "windows",
    Run CommandReader "/home/ahaskell/.config/custom/brightness.sh" "brightness",
    Run CommandReader "/home/ahaskell/.config/custom/temp.sh" "temp", 
    Run CommandReader "/home/ahaskell/.config/custom/sound.sh" "sound"
    ],
  sepChar = "%",
  alignSep = "}{",
  template = " %datetime% | %wlan% } %windows% | %sound% | %brightness% { %temp% | %cpu% | %memory% | %power% "
  }
